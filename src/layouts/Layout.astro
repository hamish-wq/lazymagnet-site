---
import '../styles/global.css';
import { SITE, NAV, isActive } from '../lib/site';

interface Props {
  title: string;
  description: string;
  canonical: string;
  keywords?: string;
  schemaJson?: object | object[];
  ogImage?: string;
}

const { title, description, canonical, keywords, schemaJson, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const og = ogImage ?? `${SITE.domain}/og-default.png`;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.domain}/#org`,
  name: 'LazyMagnet',
  url: SITE.domain,
  logo: SITE.logo,
  description: 'AI-powered customer acquisition for small and medium businesses: AI Ads and a 24/7 AI Sales Agent that responds to every lead in seconds.',
  founder: { '@type': 'Person', name: 'Hamish Nuttall' },
  areaServed: ['NZ', 'AU', 'US'],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={og} />
    <meta property="og:site_name" content="LazyMagnet" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/png" href="https://storage.googleapis.com/msgsndr/daf8wSTYyGbE6VELTA24/media/6267421957b65543aef097dd.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {schemaJson && <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />}
  </head>
  <body class="bg-white antialiased">
    <header class="bg-white/95 backdrop-blur border-b border-slate-100 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center shrink-0" aria-label="LazyMagnet home">
          <img src={SITE.logo} alt="LazyMagnet" class="h-9 md:h-10 w-auto" />
        </a>
        <nav class="hidden lg:flex items-center gap-7 text-sm font-bold">
          {NAV.map((item) => (
            <a
              href={item.href}
              class:list={[
                'transition-colors',
                isActive(currentPath, item.href) ? 'text-lm-purple' : 'text-lm-ink hover:text-lm-purple',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <a href={SITE.bookUrl} class="btn-primary !py-2.5 !px-5 text-sm shrink-0">Book a free demo</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-lm-ink text-slate-300 mt-24">
      <div class="max-w-6xl mx-auto px-4 py-14 grid md:grid-cols-4 gap-10 text-sm">
        <div class="md:col-span-1">
          <img src={SITE.logo} alt="LazyMagnet" class="h-9 w-auto mb-4 brightness-0 invert" />
          <p class="text-slate-400 leading-relaxed">
            AI that gets you more customers, generating leads and responding to every one in seconds, around the clock.
          </p>
        </div>
        <div>
          <p class="font-extrabold text-white mb-3 uppercase tracking-wide text-xs">Products</p>
          <ul class="space-y-2">
            <li><a href="/ai-ads" class="hover:text-lm-orange">AI Ads</a></li>
            <li><a href="/ai-sales-agent" class="hover:text-lm-orange">AI Sales Agent</a></li>
            <li><a href="/ultimate" class="hover:text-lm-orange">The Full System</a></li>
            <li><a href="/pricing" class="hover:text-lm-orange">Pricing</a></li>
          </ul>
        </div>
        <div>
          <p class="font-extrabold text-white mb-3 uppercase tracking-wide text-xs">Industries</p>
          <ul class="space-y-2">
            <li><a href="/industries/home-services" class="hover:text-lm-orange">Home Services & Trades</a></li>
            <li><a href="/industries/health-wellness" class="hover:text-lm-orange">Health & Wellness</a></li>
            <li><a href="/industries/professional-services" class="hover:text-lm-orange">Professional Services</a></li>
            <li><a href="/industries/ecommerce" class="hover:text-lm-orange">E-Commerce</a></li>
            <li><a href="/industries/franchise" class="hover:text-lm-orange">Franchise</a></li>
          </ul>
        </div>
        <div>
          <p class="font-extrabold text-white mb-3 uppercase tracking-wide text-xs">Company</p>
          <ul class="space-y-2">
            <li><a href="/about" class="hover:text-lm-orange">About</a></li>
            <li><a href="/get-started" class="hover:text-lm-orange">Book a demo</a></li>
            <li><a href="/contact" class="hover:text-lm-orange">Contact</a></li>
            <li><a href="/privacy" class="hover:text-lm-orange">Privacy</a></li>
            <li><a href="/terms" class="hover:text-lm-orange">Terms</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10">
        <div class="max-w-6xl mx-auto px-4 py-5 text-xs text-slate-500 flex flex-col sm:flex-row justify-between gap-2">
          <span>© LazyMagnet. AI-powered customer acquisition.</span>
          <span>New Zealand · Australia · United States</span>
        </div>
      </div>
    </footer>
  </body>
</html>
