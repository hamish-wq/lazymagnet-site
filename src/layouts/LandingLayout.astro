---
// Stripped layout for paid-traffic landing pages: NO nav (attention ratio ~1:1), one CTA goal,
// noindex (paid only, no SEO cannibalisation), minimal legal footer. Not for SEO pages.
import '../styles/global.css';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  canonical: string;
}
const { title, description, canonical } = Astro.props;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.domain,
  logo: SITE.logo,
};
---
<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- Paid landing page: keep out of the index, no cannibalising the SEO pages. -->
    <meta name="robots" content="noindex, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og-default.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>
  <body class="bg-white antialiased">
    <!-- logo only, no nav: nothing to click but the offer -->
    <header class="bg-white border-b border-slate-100">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <img src={SITE.logo} alt={SITE.name} class="h-8 md:h-9 w-auto" />
        <a href="#book" class="btn-primary !py-2 !px-4 text-sm">Book a call</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="bg-lm-ink text-slate-400 text-xs">
      <div class="max-w-5xl mx-auto px-4 py-6 flex flex-col sm:flex-row gap-2 justify-between">
        <span>© {SITE.name}</span>
        <span><a href="/privacy" class="hover:text-white">Privacy</a></span>
      </div>
    </footer>
  </body>
</html>
