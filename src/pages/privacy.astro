---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../lib/site';
const title = 'Privacy Policy | LazyMagnet';
const description = 'How LazyMagnet collects, uses and protects your information.';
const canonical = `${SITE.domain}/privacy`;
---
<Layout title={title} description={description} canonical={canonical}>
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-black mb-3">Privacy Policy</h1>
      <p class="text-lm-slate mb-8">This is placeholder copy for the demo. The live policy will carry over from the current LazyMagnet site, reviewed at cutover.</p>
      <div class="space-y-5 text-lm-slate leading-relaxed">
        <p>LazyMagnet respects your privacy. We collect only the information needed to provide our services and to respond to your enquiries.</p>
        <h2 class="text-xl text-lm-ink font-bold pt-2">What we collect</h2>
        <p>Contact details you give us, and information about how you use our website, so we can improve it and follow up on enquiries.</p>
        <h2 class="text-xl text-lm-ink font-bold pt-2">How we use it</h2>
        <p>To respond to you, to provide and improve our services, and to keep you informed where you have asked us to. We do not sell your data.</p>
        <h2 class="text-xl text-lm-ink font-bold pt-2">Your control</h2>
        <p>You can request a copy of your data or ask us to delete it at any time. Contact us and we will action it.</p>
        <p class="pt-4 text-sm">For the current full policy, please contact us. This page will be finalised before launch.</p>
      </div>
    </div>
  </section>
</Layout>
