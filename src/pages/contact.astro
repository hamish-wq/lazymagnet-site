---
import Layout from '../layouts/Layout.astro';
import Wave from '../components/Wave.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../lib/site';

const title = 'Contact LazyMagnet';
const description = 'Get in touch with LazyMagnet. Ask us anything about getting more customers with AI Ads and the AI Sales Agent. We respond fast, because that is the whole point.';
const canonical = `${SITE.domain}/contact`;
---

<Layout title={title} description={description} canonical={canonical}>
  <section class="relative overflow-hidden bg-lm-ink">
    <div class="absolute inset-0 opacity-40" style="background: radial-gradient(60% 80% at 50% 0%, #8E1491 0%, transparent 60%);"></div>
    <div class="relative max-w-3xl mx-auto px-4 py-16 md:py-20 text-center">
      <p class="text-lm-orange text-sm font-extrabold uppercase tracking-widest mb-4">Contact</p>
      <h1 class="text-4xl md:text-6xl font-black text-white leading-[1.05] mb-5">Ask us anything</h1>
      <p class="text-lg text-white/85 max-w-2xl mx-auto">Send a message and notice how fast we reply. That speed is exactly what we build for your customers.</p>
    </div>
  </section>

  <Wave from="#1A1024" to="#FFFFFF" />

  <ContactForm sourcePage="contact" eyebrow="Get in touch" heading="Send us a message" subhead="Whatever you are wondering about, ask. We will come straight back to you." />
</Layout>
