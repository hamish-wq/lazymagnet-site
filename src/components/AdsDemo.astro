---
// Self-contained mockup of AI Ads: a generated ad creative, the platforms it runs on,
// and variations being tested with a winner backed. The product demonstrating itself,
// no image asset, no brand names.
const variants = [
  { label: 'Variation A', pct: 38, win: false },
  { label: 'Variation B', pct: 71, win: true },
  { label: 'Variation C', pct: 25, win: false },
];
---
<div class="relative mx-auto w-full max-w-[360px]">
  <div class="bg-lm-ink rounded-3xl p-4 shadow-2xl ring-1 ring-white/10 space-y-3">
    <!-- platform chips -->
    <div class="flex flex-wrap gap-2">
      {['Google', 'Facebook', 'Instagram', 'YouTube'].map((p) => (
        <span class="text-[11px] font-bold text-white/80 bg-white/10 rounded-full px-2.5 py-1">{p}</span>
      ))}
    </div>

    <!-- ad creative card -->
    <div class="bg-white rounded-2xl overflow-hidden">
      <div class="h-32 relative" style="background: linear-gradient(135deg, #8E1491 0%, #FF7300 100%);">
        <span class="absolute top-2 left-2 text-[10px] font-bold text-white/90 bg-black/25 rounded px-2 py-0.5">Sponsored</span>
        <span class="absolute bottom-2 right-2 text-[11px] font-extrabold text-white">Your ad, generated</span>
      </div>
      <div class="p-3.5">
        <p class="font-bold text-sm text-lm-ink leading-tight">Same-day hot water repairs in Auckland</p>
        <p class="text-[12px] text-lm-slate mt-1 leading-snug">Burst cylinder? We can have someone out today.</p>
        <div class="mt-3 flex items-center justify-between">
          <span class="text-[11px] text-slate-400">yourbusiness.co.nz</span>
          <span class="text-[11px] font-bold text-white bg-lm-orange rounded-md px-3 py-1.5">Book now</span>
        </div>
      </div>
    </div>

    <!-- variations being tested -->
    <div class="bg-white/5 rounded-2xl p-3 space-y-2">
      <p class="text-[11px] font-bold text-white/70 uppercase tracking-wide">Testing variations</p>
      {variants.map((v) => (
        <div class="flex items-center gap-2">
          <span class:list={['text-[11px] w-20 shrink-0', v.win ? 'text-lm-orange font-bold' : 'text-white/60']}>{v.label}</span>
          <div class="flex-1 h-2 rounded-full bg-white/10 overflow-hidden">
            <div class:list={['h-full rounded-full', v.win ? 'bg-lm-orange' : 'bg-white/30']} style={`width: ${v.pct}%`}></div>
          </div>
          {v.win && <span class="text-[10px] font-bold text-lm-orange shrink-0">backing winner</span>}
        </div>
      ))}
    </div>
  </div>
  <p class="text-center text-sm text-white/70 mt-4 font-semibold">Creates variations, runs them, backs the winner.</p>
</div>
