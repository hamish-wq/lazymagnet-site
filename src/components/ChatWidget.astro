---
// Standard-build chat widget mount.
// PRODUCTION: replace the placeholder below with the white-labelled AI Sales Agent
// chat widget script (the same widget included in every standard build). The placeholder
// is functional for the demo: it opens a panel that routes to booking, so the page is
// never dead, but it is NOT the live agent.
---
<div id="lm-chat" class="fixed bottom-5 right-5 z-50">
  <button
    id="lm-chat-toggle"
    class="w-14 h-14 rounded-full bg-lm-orange text-white shadow-2xl flex items-center justify-center hover:bg-lm-orange-dark transition"
    aria-label="Chat with us"
  >
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
  </button>
  <div id="lm-chat-panel" class="hidden absolute bottom-16 right-0 w-72 bg-white rounded-2xl shadow-2xl border border-slate-200 overflow-hidden">
    <div class="bg-lm-purple text-white px-4 py-3">
      <p class="font-bold text-sm">Chat with us</p>
      <p class="text-[11px] text-white/70">Replies in seconds, 24/7</p>
    </div>
    <div class="p-4 text-sm text-lm-slate">
      <p class="mb-3">Hi! Ask us anything about getting more customers, or book a quick demo.</p>
      <a href="/get-started" class="btn-primary w-full !py-2.5 text-sm">Book a free demo</a>
    </div>
  </div>
</div>
<script>
  const toggle = document.getElementById('lm-chat-toggle');
  const panel = document.getElementById('lm-chat-panel');
  toggle?.addEventListener('click', () => panel?.classList.toggle('hidden'));
</script>
