---
interface Props {
  sourcePage: string;
  eyebrow?: string;
  heading?: string;
  subhead?: string;
  dark?: boolean;
}
const {
  sourcePage,
  eyebrow = 'Quick question?',
  heading = 'Send us a message',
  subhead = "Tell us what you're trying to fix. We'll come straight back to you, usually within minutes.",
  dark = false,
} = Astro.props;
---
<section class:list={[dark ? 'bg-lm-ink' : 'bg-white', 'py-16 md:py-20']}>
  <div class="max-w-3xl mx-auto px-4">
    <div class="text-center mb-10">
      <p class="text-lm-orange text-sm font-extrabold uppercase tracking-widest mb-2">{eyebrow}</p>
      <h2 class:list={['text-3xl md:text-4xl mb-3', dark && 'text-white']}>{heading}</h2>
      <p class:list={[dark ? 'text-slate-300' : 'text-lm-slate']}>{subhead}</p>
    </div>
    <form
      action="/api/contact"
      method="POST"
      data-webhook="TODO_WIRE_GHL_INBOUND_WEBHOOK"
      class:list={[
        'rounded-3xl p-8 md:p-10 space-y-5 border',
        dark ? 'bg-white/5 border-white/10' : 'bg-lm-purple-light border-purple-100',
      ]}
    >
      <input type="hidden" name="source_page" value={sourcePage} />
      <input type="hidden" name="utm_source" id="utm_source" />
      <input type="hidden" name="utm_medium" id="utm_medium" />
      <input type="hidden" name="utm_campaign" id="utm_campaign" />
      <input type="hidden" name="gclid" id="gclid" />
      <input type="hidden" name="fbclid" id="fbclid" />

      <div class="grid md:grid-cols-2 gap-5">
        <label class="block">
          <span class:list={['text-sm font-bold mb-1.5 block', dark ? 'text-white' : 'text-lm-ink']}>Your name</span>
          <input type="text" name="full_name" required class="w-full px-4 py-3 bg-white border border-slate-200 rounded-full focus:outline-none focus:border-lm-purple focus:ring-2 focus:ring-lm-purple/20" />
        </label>
        <label class="block">
          <span class:list={['text-sm font-bold mb-1.5 block', dark ? 'text-white' : 'text-lm-ink']}>Phone</span>
          <input type="tel" name="phone" required inputmode="tel" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-full focus:outline-none focus:border-lm-purple focus:ring-2 focus:ring-lm-purple/20" />
        </label>
      </div>
      <label class="block">
        <span class:list={['text-sm font-bold mb-1.5 block', dark ? 'text-white' : 'text-lm-ink']}>Email</span>
        <input type="email" name="email" required class="w-full px-4 py-3 bg-white border border-slate-200 rounded-full focus:outline-none focus:border-lm-purple focus:ring-2 focus:ring-lm-purple/20" />
      </label>
      <label class="block">
        <span class:list={['text-sm font-bold mb-1.5 block', dark ? 'text-white' : 'text-lm-ink']}>What are you trying to fix?</span>
        <textarea name="message" rows="3" placeholder="e.g. We're getting leads from ads but half of them go cold before we call back." class="w-full px-4 py-3 bg-white border border-slate-200 rounded-2xl focus:outline-none focus:border-lm-purple focus:ring-2 focus:ring-lm-purple/20"></textarea>
      </label>
      <div class="flex flex-col sm:flex-row gap-3 items-center justify-between pt-1">
        <p class:list={['text-xs', dark ? 'text-slate-400' : 'text-slate-500']}>No obligation. We'll point you in the right direction even if it's not us.</p>
        <button type="submit" class="btn-primary">Send message</button>
      </div>
    </form>
  </div>
</section>

<script>
  const params = new URLSearchParams(window.location.search);
  ['utm_source', 'utm_medium', 'utm_campaign', 'gclid', 'fbclid'].forEach((k) => {
    const el = document.getElementById(k) as HTMLInputElement | null;
    const v = params.get(k);
    if (el && v) el.value = v;
  });
</script>
